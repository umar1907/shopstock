<style>
  .mobile-menu-drawer {
    position: fixed; top: 0; left: -100%; width: 100%; height: 100vh;
    z-index: 1000; display: flex; transition: left 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .mobile-menu-drawer.is-open { left: 0; }
  .mobile-menu-overlay { width: 20%; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); }
  .mobile-menu-panel { width: 80%; max-width: 400px; background: var(--color-white); height: 100%; display: flex; flex-direction: column; box-shadow: 20px 0 40px rgba(0,0,0,0.1); }
  .mobile-menu-header { padding: 20px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--color-border); }
  .mobile-menu-content { flex: 1; overflow-y: auto; padding: 20px 0; }
  .mobile-menu-footer { padding: 20px; border-top: 1px solid var(--color-border); background: var(--color-background); }
  .accordion-item { border-bottom: 1px solid var(--color-border); }
  .accordion-trigger { width: 100%; text-align: left; background: none; border: none; padding: 16px 20px; font-size: 16px; font-weight: 600; color: var(--color-secondary); display: flex; justify-content: space-between; align-items: center; }
  .accordion-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; background: var(--color-background); }
  .accordion-link { display: block; padding: 12px 40px; color: var(--color-text); text-decoration: none; font-size: 15px; }
</style>

<div id="MobileMenu" class="mobile-menu-drawer mobile-only">
  <div class="mobile-menu-panel">
    <div class="mobile-menu-header">
      <span class="logo-title" style="font-size: 18px;">STOCKSHOP</span>
      <button class="close-mobile-menu" aria-label="Close menu" style="background:none; border:none; padding:4px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="mobile-menu-content">
      <div class="accordion-item">
        <button class="accordion-trigger" aria-expanded="false">Categories <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></button>
        <div class="accordion-content">
          <a href="#" class="accordion-link">Livestock</a>
          <a href="#" class="accordion-link">Equipment</a>
          <a href="#" class="accordion-link">Services</a>
        </div>
      </div>
      <a href="#" class="accordion-trigger" style="text-decoration:none;">Membership</a>
      <a href="#" class="accordion-trigger" style="text-decoration:none;">FAQ</a>
      <a href="#" class="accordion-trigger" style="text-decoration:none;">Contact</a>
    </div>
    <div class="mobile-menu-footer">
      <a href="{{ section.settings.main_cta_link }}" class="btn-main-cta" style="width: 100%; text-align: center; padding: 14px;">{{ section.settings.main_cta_text }}</a>
    </div>
  </div>
  <div class="mobile-menu-overlay"></div>
</div>
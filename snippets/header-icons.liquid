<style>
  .icon-group { display: flex; align-items: center; gap: 12px; }
  .icon-btn {
    width: 44px; height: 44px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: transparent; color: var(--color-text);
    text-decoration: none; border: 1px solid transparent;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }
  .icon-btn:hover {
    background: var(--color-primary); color: var(--color-white);
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 6px 16px rgba(199, 154, 59, 0.25);
  }
  .cart-badge {
    position: absolute; top: -2px; right: -2px;
    background: var(--color-primary); color: var(--color-white);
    font-size: 11px; font-weight: 700; width: 18px; height: 18px;
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    border: 2px solid var(--color-white);
    animation: popIn 0.3s ease forwards;
  }
  .icon-btn:hover .cart-badge { background: var(--color-white); color: var(--color-primary); border-color: var(--color-primary); }

  .profile-wrapper { position: relative; }
  .profile-dropdown {
    position: absolute; top: 120%; right: 0; width: 220px;
    background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(15px);
    border: 1px solid var(--color-border); border-radius: 12px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
    opacity: 0; visibility: hidden; transform: translateY(10px);
    transition: all 0.3s ease; padding: 12px; z-index: 100;
  }
  .profile-wrapper:hover .profile-dropdown { opacity: 1; visibility: visible; transform: translateY(0); }
  .dropdown-item {
    display: flex; align-items: center; gap: 12px; padding: 10px 12px;
    color: var(--color-text); text-decoration: none; font-size: 14px; font-weight: 500;
    border-radius: 8px; transition: all 0.2s ease;
  }
  .dropdown-item:hover { background: var(--color-primary); color: var(--color-white); }
</style>

<div class="icon-group">
  <a href="#wishlist" class="icon-btn desktop-only" aria-label="Wishlist">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
  </a>
  <a href="#compare" class="icon-btn desktop-only" aria-label="Compare">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M13 6h3a2 2 0 0 1 2 2v7"/><path d="M11 18H8a2 2 0 0 1-2-2V9"/></svg>
  </a>
  <a href="#notifications" class="icon-btn desktop-only" aria-label="Notifications">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
  </a>
  <a href="{{ routes.cart_url }}" class="icon-btn" aria-label="Cart">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
    <span class="cart-badge">{{ cart.item_count }}</span>
  </a>

  <div class="profile-wrapper desktop-only">
    <a href="{{ routes.account_url }}" class="icon-btn" aria-label="Profile">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    </a>
    <div class="profile-dropdown">
      <a href="{{ routes.account_url }}" class="dropdown-item">My Account</a>
      <a href="#orders" class="dropdown-item">Orders</a>
      <a href="#wishlist" class="dropdown-item">Wishlist</a>
      <a href="#messages" class="dropdown-item">Messages</a>
      <a href="#settings" class="dropdown-item">Settings</a>
      <a href="{{ routes.account_logout_url }}" class="dropdown-item">Logout</a>
    </div>
  </div>
</div>
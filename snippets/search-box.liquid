<style>
  .search-wrapper {
    display: flex;
    align-items: center;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 6px 6px 6px 20px;
    width: 100%;
    max-width: 700px;
    transition: all 0.3s ease;
    position: relative;
  }
  .search-wrapper:hover, .search-wrapper:focus-within {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 4px rgba(199, 154, 59, 0.1);
  }
  .search-icon { color: #A0A0A0; margin-right: 12px; }
  .search-input {
    border: none; background: transparent; flex: 1;
    font-size: 15px; color: var(--color-text); outline: none;
  }
  .search-divider { width: 1px; height: 24px; background: var(--color-border); margin: 0 16px; }
  .search-category-select {
    border: none; background: transparent; outline: none;
    font-size: 14px; font-weight: 500; color: var(--color-text);
    cursor: pointer; padding-right: 8px; appearance: none;
  }
  .search-btn {
    background: var(--color-primary); color: var(--color-white);
    border: none; border-radius: 12px; padding: 10px 24px;
    font-weight: 600; cursor: pointer; transition: all 0.3s ease;
    margin-left: 12px;
  }
  .search-btn:hover { background: var(--color-secondary); transform: scale(1.02); }
</style>

<form action="{{ routes.search_url }}" method="get" class="search-wrapper" role="search">
  <svg class="search-icon lucide lucide-search" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
  <input type="search" name="q" class="search-input" placeholder="{{ section.settings.search_placeholder }}" aria-label="Search">
  <div class="search-divider desktop-only"></div>
  <select name="type" class="search-category-select desktop-only" aria-label="Category">
    <option value="">All Categories</option>
    <option value="livestock">Livestock</option>
    <option value="equipment">Equipment</option>
    <option value="services">Services</option>
  </select>
  <button type="submit" class="search-btn desktop-only">Search</button>
</form>
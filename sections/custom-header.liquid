{{ 'header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'header.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  :root {
    --color-primary: {{ section.settings.color_primary }};
    --color-secondary: {{ section.settings.color_secondary }};
    --color-background: {{ section.settings.color_background }};
    --color-white: {{ section.settings.color_white }};
    --color-text: {{ section.settings.color_text }};
    --color-border: {{ section.settings.color_border }};
    --header-height: {{ section.settings.header_height }}px;
    --sticky-height: {{ section.settings.sticky_height }}px;
  }
{%- endstyle -%}

<header id="StockShopHeader" class="stockshop-header {% if section.settings.enable_sticky %}sticky-enabled{% endif %}">
  
  {%- if section.settings.show_topbar -%}
    <div class="header-topbar">
      <div class="topbar-container">
        <div class="topbar-left">
          {%- if section.settings.phone != blank -%}
            <a href="tel:{{ section.settings.phone | remove: ' ' }}" class="topbar-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              {{ section.settings.phone }}
            </a>
          {%- endif -%}
          {%- if section.settings.email != blank -%}
            <a href="mailto:{{ section.settings.email }}" class="topbar-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              {{ section.settings.email }}
            </a>
          {%- endif -%}
        </div>
        
        <div class="topbar-center">
          <span class="topbar-announcement">{{ section.settings.announcement_text }}</span>
        </div>

        <div class="topbar-right">
          <div class="topbar-socials">
            {%- if section.settings.social_fb != blank -%}<a href="{{ section.settings.social_fb }}" aria-label="Facebook">FB</a>{%- endif -%}
            {%- if section.settings.social_ig != blank -%}<a href="{{ section.settings.social_ig }}" aria-label="Instagram">IG</a>{%- endif -%}
            {%- if section.settings.social_yt != blank -%}<a href="{{ section.settings.social_yt }}" aria-label="YouTube">YT</a>{%- endif -%}
          </div>
          {%- if section.settings.seller_cta_text != blank -%}
            <a href="{{ section.settings.seller_cta_link }}" class="btn-small-gold">{{ section.settings.seller_cta_text }}</a>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  <div class="header-main">
    <div class="header-main-container">
      
      <div class="header-logo">
        <button type="button" class="drawer-toggle-btn js-drawer-open" aria-label="Open menu">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        </button>
        <a href="{{ routes.root_url }}">
          {%- if section.settings.logo != blank -%}
            <img src="{{ section.settings.logo | image_url: width: 300 }}" alt="{{ shop.name }}" width="{{ section.settings.logo_width }}" height="auto" loading="lazy">
          {%- else -%}
            <div class="logo-text-wrapper">
              <span class="logo-title">STOCKSHOP</span>
              <span class="logo-subtitle">Your Livestock Marketplace</span>
            </div>
          {%- endif -%}
        </a>
      </div>

      <div class="header-search desktop-only">
        {% render 'search-box', section: section %}
      </div>

      <div class="header-actions">
        {% render 'header-icons', section: section %}
        <a href="{{ section.settings.main_cta_link }}" class="btn-main-cta desktop-only" style="margin-left: 12px;">{{ section.settings.main_cta_text }}</a>
      </div>

    </div>
  </div>

  <div class="mobile-search-row mobile-only">
    {% render 'search-box', section: section %}
  </div>

</header>

<div id="SiteDrawer" class="site-drawer">
  <div class="drawer-overlay js-drawer-close"></div>
  <div class="drawer-panel">
    
    <div class="drawer-header">
      <div class="logo-text-wrapper">
        <span class="logo-title" style="font-size: 20px;">STOCKSHOP</span>
      </div>
      <button class="drawer-close-btn js-drawer-close" aria-label="Close menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <div class="drawer-content">
      <ul class="drawer-nav-list">
        {%- for link in section.settings.menu.links -%}
          <li class="drawer-nav-item">
            <a href="{{ link.url }}" class="drawer-nav-link">{{ link.title }}</a>
          </li>
        {%- endfor -%}
      </ul>
    </div>

    <div class="drawer-footer mobile-only">
      <a href="{{ section.settings.main_cta_link }}" class="btn-main-cta" style="width: 100%; display: flex; justify-content: center;">
        {{ section.settings.main_cta_text }}
      </a>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Premium Custom Header",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    { "type": "color", "id": "color_primary", "label": "Primary (Gold)", "default": "#C79A3B" },
    { "type": "color", "id": "color_secondary", "label": "Secondary (Dark Green)", "default": "#1E2F20" },
    { "type": "color", "id": "color_background", "label": "Background", "default": "#F8F7F3" },
    { "type": "color", "id": "color_white", "label": "White", "default": "#FFFFFF" },
    { "type": "color", "id": "color_text", "label": "Text", "default": "#232323" },
    { "type": "color", "id": "color_border", "label": "Light Gray", "default": "#E9E8E4" },
    {
      "type": "header",
      "content": "Header Layout"
    },
    { "type": "range", "id": "header_height", "label": "Main Header Height", "min": 70, "max": 120, "step": 5, "default": 90 },
    { "type": "range", "id": "sticky_height", "label": "Sticky Header Height", "min": 50, "max": 90, "step": 5, "default": 70 },
    { "type": "checkbox", "id": "enable_sticky", "label": "Enable Sticky Header", "default": true },
    {
      "type": "header",
      "content": "Top Bar"
    },
    { "type": "checkbox", "id": "show_topbar", "label": "Show Top Bar", "default": true },
    { "type": "text", "id": "phone", "label": "Phone Number", "default": "+1 (555) 123-4567" },
    { "type": "text", "id": "email", "label": "Email", "default": "hello@stockshop.com" },
    { "type": "text", "id": "announcement_text", "label": "Announcement", "default": "List your livestock for FREE" },
    { "type": "text", "id": "seller_cta_text", "label": "Seller CTA Text", "default": "Become a Seller" },
    { "type": "url", "id": "seller_cta_link", "label": "Seller CTA Link" },
    { "type": "url", "id": "social_fb", "label": "Facebook Link" },
    { "type": "url", "id": "social_ig", "label": "Instagram Link" },
    { "type": "url", "id": "social_yt", "label": "YouTube Link" },
    {
      "type": "header",
      "content": "Main Header"
    },
    { "type": "image_picker", "id": "logo", "label": "Logo Image" },
    { "type": "range", "id": "logo_width", "label": "Logo Width", "min": 100, "max": 300, "step": 10, "default": 200 },
    { "type": "text", "id": "search_placeholder", "label": "Search Placeholder", "default": "Search cattle, horses, goats, sheep..." },
    {
      "type": "header",
      "content": "Navigation"
    },
    { "type": "link_list", "id": "menu", "label": "Main Menu", "default": "main-menu" },
    { "type": "text", "id": "main_cta_text", "label": "Main CTA Button Text", "default": "SELL LIVESTOCK" },
    { "type": "url", "id": "main_cta_link", "label": "Main CTA Button Link" }
  ],
  "presets": [
    {
      "name": "Custom Premium Header"
    }
  ]
}
{% endschema %}
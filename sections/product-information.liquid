<script type="application/ld+json">
  {{ closest.product | structured_data }}
</script>

{% capture media_gallery %}
  {%- content_for 'block',
    type: '_product-media-gallery',
    id: 'media-gallery',
    closest.product: closest.product
  -%}
{% endcapture %}

{% capture product_details %}
  {% content_for 'block',
    type: '_product-details',
    id: 'product-details',
    closest.product: closest.product
  %}
{% endcapture %}

{% capture additional_blocks %}
  {% content_for 'blocks' %}
{% endcapture %}

{% if section.settings.enable_sticky_add_to_cart %}
  {% liquid
    assign current_variant = product.selected_or_first_available_variant
    # Get the initial quantity based on quantity rules
    assign initial_quantity = current_variant.quantity_rule.min | default: 1
  %}

  <sticky-add-to-cart
    class="sticky-add-to-cart"
    data-variant-available="{{ current_variant.available }}"
    data-product-id="{{ product.id }}"
    data-current-variant-id="{{ current_variant.id }}"
    data-initial-quantity="{{ initial_quantity }}"
    data-default-variant-title="{{ 'products.product.default_title' | t }}"
  >
    <div
      class="sticky-add-to-cart__bar color-custom-popover"
      data-stuck="false"
      ref="stickyBar"
      role="region"
      aria-label="{{ 'products.product.sticky_add_to_cart' | t }}"
    >
      {% liquid
        assign image_to_show = current_variant.featured_image | default: product.featured_image
      %}
      {% if image_to_show %}
        <div
          class="sticky-add-to-cart__image"
        >
          {% assign image_alt = image_to_show.alt | default: product.title | escape %}
          {{
            image_to_show
            | image_url: width: 120
            | image_tag:
              loading: 'lazy',
              alt: image_alt,
              class: 'sticky-add-to-cart__image-img',
              data-testid: 'sticky-product-image',
              srcset: null,
              sizes: null,
              ref: 'productImage'
          }}
        </div>
      {% endif %}

      {% liquid
        assign has_single_option = false
        if product.has_only_default_variant != true and product.options.size == 1
          assign has_single_option = true
        endif

        if image_to_show == blank
          assign has_image = false
        else
          assign has_image = true
        endif
      %}
      <div
        class="sticky-add-to-cart__info"
        data-has-image="{{ has_image }}"
        data-singleton="{{ product.has_only_default_variant }}"
        data-single-option="{{ has_single_option }}"
      >
        <p
          class="sticky-add-to-cart__title"
          data-testid="sticky-product-title"
        >
          {{ product.title | escape }}
        </p>
        <div
          class="sticky-add-to-cart__variant"
          data-testid="sticky-variant-title"
          {% if product.has_only_default_variant %}
            style="display: none;"
          {% endif %}
        >
          {% unless product.has_only_default_variant %}
            {% if current_variant != blank %}
              {% assign variant_title = current_variant.title | escape %}
            {% endif %}
            {{ variant_title }}
          {% endunless %}
        </div>
      </div>

      <div
        class="sticky-add-to-cart__price"
        data-testid="sticky-price-display"
      >
        {% render 'price', product_resource: product, show_sale_price_first: true %}
      </div>

      <button
        type="button"
        class="sticky-add-to-cart__button add-to-cart-button button"
        ref="addToCartButton"
        on:click="/handleAddToCartClick"
        {% unless current_variant.available %}
          disabled
        {% endunless %}
      >
        <span
          class="add-to-cart-text"
        >
          {% if current_variant.available %}
            <span class="svg-wrapper">
              {{- 'icon-add-to-cart.svg' | inline_asset_content -}}
            </span>
          {% endif %}
          <span class="add-to-cart-text__content">
            <span>
              {%- if current_variant.available -%}
                {{- 'products.product.add_to_cart' | t -}}
              {%- elsif current_variant == blank -%}
                {{- 'products.product.unavailable' | t -}}
              {%- else -%}
                {{- 'products.product.sold_out' | t -}}
              {%- endif -%}
            </span>
            <span
              ref="quantityDisplay"
              {% if current_variant.available and initial_quantity > 1 %}
                style="display: inline;"
              {% else %}
                style="display: none;"
              {% endif %}
            >
              {{- ' (' -}}
              <span ref="quantityNumber">{{- initial_quantity -}}</span>
              {{- ')' -}}
            </span>
          </span>
        </span>
        <span class="add-to-cart__added">
          <span class="svg-wrapper add-to-cart__added-icon">
            {{- 'icon-checkmark-burst.svg' | inline_asset_content -}}
          </span>
        </span>
      </button>
    </div>
  </sticky-add-to-cart>
{% endif %}

{% render 'product-information-content',
  product: closest.product,
  section_id: section.id,
  settings: section.settings,
  media_gallery: media_gallery,
  product_details: product_details,
  additional_blocks: additional_blocks
%}

<style>
  #shopify-section-{{ section.id }} .product-information__media {
    --pi-media-counter: '1 / {{ closest.product.media.size }}';
  }
</style>

{% stylesheet %}
  .product-information {
    --pi-ink: #161511;
    --pi-muted: rgb(22 21 17 / 0.62);
    --pi-line: rgb(22 21 17 / 0.1);
    --pi-gold: #b88935;
    --pi-gold-soft: #f6ead2;
    --pi-green: #173f34;
    --pi-cream: #fbfaf7;
    --pi-glass: rgb(255 255 255 / 0.74);
    --pi-shadow: 0 24px 70px rgb(22 21 17 / 0.11);
    --pi-shadow-soft: 0 14px 36px rgb(22 21 17 / 0.08);
    --pi-radius-xl: 32px;
    --pi-radius-lg: 22px;
    --pi-radius-md: 18px;
    color: var(--pi-ink);
    max-width: 1600px;
    margin-inline: auto;
    padding-block: max(var(--padding-block-start, 0px), 80px) max(var(--padding-block-end, 0px), 80px);
  }

  .product-information.section--full-width {
    max-width: 1600px;
    padding-inline: clamp(18px, 4vw, 56px);
  }

  .product-information__grid {
    gap: clamp(28px, 4.5vw, 72px);
    align-items: start;
  }

  .product-information__media {
    position: relative;
    isolation: isolate;
  }

  .product-information__media::before {
    content: 'NEW';
    position: absolute;
    inset-block-start: clamp(14px, 2vw, 22px);
    inset-inline-start: clamp(14px, 2vw, 22px);
    z-index: 3;
    padding: 9px 14px;
    border: 1px solid rgb(255 255 255 / 0.54);
    border-radius: 999px;
    background: rgb(255 255 255 / 0.72);
    color: var(--pi-ink);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1;
    backdrop-filter: blur(18px);
  }

  .product-information__media::after {
    content: var(--pi-media-counter, '1 / 1');
    position: absolute;
    inset-block-start: clamp(14px, 2vw, 22px);
    inset-inline-end: clamp(14px, 2vw, 22px);
    z-index: 3;
    padding: 9px 14px;
    border: 1px solid rgb(255 255 255 / 0.54);
    border-radius: 999px;
    background: rgb(255 255 255 / 0.72);
    color: var(--pi-ink);
    font-size: 0.78rem;
    font-weight: 650;
    line-height: 1;
    backdrop-filter: blur(18px);
  }

  .product-information__media :is(media-gallery, .media-gallery, slideshow-component) {
    display: block;
    overflow: hidden;
    border: 1px solid var(--pi-line);
    border-radius: var(--pi-radius-xl);
    background: #fff;
    box-shadow: var(--pi-shadow);
  }

  .product-information__media :is(.product-media, .product-media-container, slideshow-slide) {
    overflow: hidden;
    border-radius: calc(var(--pi-radius-xl) - 8px);
    background: #fff;
  }

  .product-information__media :is(img, video, model-viewer) {
    transition: transform 420ms var(--ease-out-quad, ease);
  }

  .product-information__media :is(.product-media, .product-media-container, slideshow-slide):hover :is(img, video, model-viewer) {
    transform: scale(1.04);
  }

  .product-information__media :is(slideshow-controls[thumbnails], .slideshow-controls--thumbnails, .media-gallery__thumbnail-list) {
    gap: 12px;
    padding: 14px;
  }

  .product-information__media :is(.thumbnail, .slideshow-control, button[aria-label*='Slide']) {
    overflow: hidden;
    border: 1px solid rgb(22 21 17 / 0.12);
    border-radius: var(--pi-radius-md);
    background: #fff;
    box-shadow: 0 8px 22px rgb(22 21 17 / 0.08);
    transition: transform 220ms var(--ease-out-quad, ease), border-color 220ms ease, box-shadow 220ms ease;
  }

  .product-information__media :is(.thumbnail, .slideshow-control, button[aria-label*='Slide']):hover {
    transform: translateY(-2px) scale(1.02);
    border-color: rgb(184 137 53 / 0.5);
  }

  .product-information__media :is([aria-current='true'], [aria-selected='true'], .is-active) {
    border-color: var(--pi-gold);
    box-shadow: 0 0 0 4px rgb(184 137 53 / 0.14), 0 10px 28px rgb(22 21 17 / 0.1);
  }

  .product-information__media :is(.media-gallery__zoom, .product-media-modal__button, button[name='zoom']) {
    border: 1px solid rgb(255 255 255 / 0.6);
    border-radius: 999px;
    background: var(--pi-glass);
    box-shadow: var(--pi-shadow-soft);
    backdrop-filter: blur(16px);
    transition: transform 220ms var(--ease-out-quad, ease), background 220ms ease;
  }

  .product-information__media :is(.media-gallery__zoom, .product-media-modal__button, button[name='zoom']):hover {
    transform: translateY(-2px) scale(1.05);
    background: #fff;
  }

  .product-details > .group-block {
    overflow: hidden;
    border: 1px solid var(--pi-line);
    border-radius: var(--pi-radius-xl);
    background:
      linear-gradient(145deg, rgb(255 255 255 / 0.96), rgb(251 250 247 / 0.94)),
      #fff;
    box-shadow: var(--pi-shadow);
    padding: clamp(24px, 3.2vw, 48px);
  }

  .product-details :is(.breadcrumbs, .breadcrumb, nav[aria-label='Breadcrumb']) {
    color: var(--pi-muted);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .product-details :is(h1, .product-title, .product-title__title, [data-testid='product-title']) {
    max-width: 12ch;
    color: var(--pi-ink);
    font-family: "Playfair Display", Georgia, "Times New Roman", serif;
    font-size: clamp(2.45rem, 4.2vw, 3.625rem);
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.1;
  }

  .product-details :is(product-price, .price, .price-list) {
    color: var(--pi-gold);
    font-size: clamp(1.45rem, 2.1vw, 2rem);
    font-weight: 750;
    letter-spacing: 0;
  }

  .product-details :is(.compare-at-price, s, .price__compare) {
    color: rgb(22 21 17 / 0.42);
    font-size: 0.72em;
    font-weight: 500;
  }

  .product-details :is(.sale, .badge, .price__badge-sale) {
    border-radius: 999px;
    background: rgb(29 122 87 / 0.12);
    color: #1d7a57;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .product-details :is(.rte, .text-block, .product-description) {
    max-width: 600px;
    color: var(--pi-muted);
    font-size: clamp(1rem, 1.1vw, 1.08rem);
    line-height: 1.75;
  }

  .product-details :is(variant-picker, .variant-picker) {
    --variant-picker-button-radius: 18px;
    --variant-picker-swatch-radius: 18px;
  }

  .product-details :is(.variant-option__button-label, .variant-option__button, .variant-picker__option button, .variant-picker select) {
    border: 1px solid rgb(22 21 17 / 0.12);
    border-radius: var(--pi-radius-md);
    background: rgb(255 255 255 / 0.76);
    box-shadow: 0 8px 20px rgb(22 21 17 / 0.05);
    transition: transform 180ms var(--ease-out-quad, ease), border-color 180ms ease, background 180ms ease, color 180ms ease;
  }

  .product-details :is(.variant-option__button-label, .variant-option__button, .variant-picker__option button):hover {
    transform: translateY(-1px);
    border-color: rgb(184 137 53 / 0.54);
  }

  .product-details :is(input:checked + .variant-option__button-label, [aria-pressed='true'], [aria-selected='true']) {
    border-color: var(--pi-gold);
    background: var(--pi-gold);
    color: #fff;
  }

  .product-details :is(.quantity-selector-wrapper, .quantity-selector) {
    border-radius: var(--pi-radius-md);
  }

  .product-details .quantity-selector {
    min-height: 58px;
    border: 1px solid var(--pi-line);
    background: rgb(255 255 255 / 0.76);
    box-shadow: 0 10px 24px rgb(22 21 17 / 0.06);
  }

  .product-details .quantity-selector :is(button, input) {
    min-height: 56px;
  }

  .product-details .quantity-selector button {
    transition: transform 180ms var(--ease-out-quad, ease), background 180ms ease;
  }

  .product-details .quantity-selector button:hover {
    transform: translateY(-1px);
    background: var(--pi-gold-soft);
  }

  .product-details :is(.buy-buttons-block, product-form-component) {
    width: 100%;
  }

  .product-details :is(.buy-buttons-block__bar, .shopify-payment-button__button, .add-to-cart-button, button[type='submit']) {
    min-height: 62px;
    border-radius: var(--pi-radius-md);
  }

  .product-details :is(.add-to-cart-button, button[type='submit'].add-to-cart-button) {
    border: 0;
    background: var(--pi-gold);
    color: #161511;
    font-weight: 800;
    transition: transform 220ms var(--ease-out-quad, ease), background 220ms ease;
  }

  .product-details :is(.add-to-cart-button, button[type='submit'].add-to-cart-button):hover {
    transform: translateY(-2px);
    background: #c99945;
  }

  .product-details .shopify-payment-button__button {
    overflow: hidden;
    background: var(--pi-green);
    color: #fff;
    font-weight: 800;
    transition: transform 220ms var(--ease-out-quad, ease), background 220ms ease;
  }

  .product-details .shopify-payment-button__button:hover {
    transform: translateY(-2px);
    background: #0f2f27;
  }

  .product-details .buy-buttons-block::after {
    content: 'Secure checkout  \00B7  Verified marketplace  \00B7  Fast shipping  \00B7  Money back  \00B7  Premium support';
    display: block;
    margin-block-start: 18px;
    padding: 16px 18px;
    border: 1px solid rgb(255 255 255 / 0.68);
    border-radius: var(--pi-radius-lg);
    background: rgb(255 255 255 / 0.62);
    color: var(--pi-muted);
    font-size: 0.86rem;
    font-weight: 650;
    line-height: 1.7;
    box-shadow: 0 12px 30px rgb(22 21 17 / 0.06);
    backdrop-filter: blur(16px);
  }

  .product-details product-inventory {
    display: block;
    padding: 14px 16px;
    border: 1px solid rgb(29 122 87 / 0.16);
    border-radius: var(--pi-radius-lg);
    background: rgb(29 122 87 / 0.07);
  }

  .product-details .product-inventory__status {
    gap: 10px;
    font-size: 1rem;
    font-weight: 700;
  }

  .product-details .product-inventory__icon {
    position: relative;
    width: 12px;
    height: 12px;
    border-radius: 999px;
    background: #1d7a57;
  }

  .product-details .product-inventory__icon::after {
    content: '';
    position: absolute;
    inset: -5px;
    border-radius: inherit;
    background: rgb(29 122 87 / 0.16);
    animation: pi-stock-pulse 1.8s ease-out infinite;
  }

  .product-details .product-inventory__icon svg {
    display: none;
  }

  .product-details :is(.accordion, accordion-custom, .details) {
    border-radius: var(--pi-radius-lg);
  }

  .product-details accordion-custom {
    overflow: hidden;
    border: 1px solid var(--pi-line);
    background: rgb(255 255 255 / 0.72);
  }

  .product-details :is(summary, .summary) {
    transition: background 180ms ease;
  }

  .product-details :is(summary, .summary):hover {
    background: rgb(184 137 53 / 0.08);
  }

  .product-details :is(.share-button, .social-sharing, .wishlist, .compare) button,
  .product-details :is(a[href*='facebook'], a[href*='pinterest'], a[href*='twitter'], a[href*='x.com']) {
    border-radius: 999px;
    transition: transform 180ms var(--ease-out-quad, ease), background 180ms ease;
  }

  .product-details :is(.share-button, .social-sharing, .wishlist, .compare) button:hover,
  .product-details :is(a[href*='facebook'], a[href*='pinterest'], a[href*='twitter'], a[href*='x.com']):hover {
    transform: translateY(-2px);
    background: var(--pi-gold-soft);
  }

  @keyframes pi-stock-pulse {
    0% {
      opacity: 0.9;
      transform: scale(0.78);
    }

    100% {
      opacity: 0;
      transform: scale(1.7);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-information *,
    .sticky-add-to-cart__bar * {
      animation-duration: 1ms !important;
      transition-duration: 1ms !important;
    }
  }

  @media screen and (min-width: 750px) {
    .product-information__grid:not(.product-information--media-none).product-information--media-left,
    .product-information__grid:not(.product-information--media-none).product-information--media-right {
      grid-template-columns: minmax(0, 55fr) minmax(360px, 45fr);
    }

    .product-information__grid:not(.product-information--media-none).product-information--media-right {
      grid-template-columns: minmax(360px, 45fr) minmax(0, 55fr);
    }

    .product-information__grid:not(.product-information--media-none) .product-information__media,
    .product-information__grid:not(.product-information--media-none) .product-details {
      padding-inline: 0 !important;
    }

    .product-details.sticky-content--desktop {
      top: calc(var(--sticky-header-offset, 0px) + 24px);
    }
  }

  @media screen and (max-width: 989px) {
    .product-information {
      padding-block: 48px;
    }

    .product-information__grid {
      display: flex;
      flex-direction: column;
    }

    .product-information__media,
    .product-details {
      width: 100%;
    }
  }

  @media screen and (max-width: 749px) {
    .product-information {
      padding-inline: 16px;
      padding-block: 28px 96px;
    }

    .product-information__media::before {
      content: 'VERIFIED';
    }

    .product-information__media :is(media-gallery, .media-gallery, slideshow-component),
    .product-details > .group-block {
      border-radius: 24px;
    }

    .product-details > .group-block {
      padding: 22px;
    }

    .product-details :is(h1, .product-title, .product-title__title, [data-testid='product-title']) {
      max-width: 100%;
    }

    .product-details .buy-buttons-block::after {
      content: 'Secure checkout  \00B7  Fast shipping  \00B7  Money back';
    }
  }

  .sticky-add-to-cart__bar {
    position: fixed;
    bottom: 20px;
    left: 50%;
    opacity: 0;
    transform: translateX(-50%) translateY(calc(100% + 40px));
    z-index: calc(var(--layer-sticky) - 1); /* Below sticky header */
    display: block;
    width: min(760px, calc(100vw - 32px));
    border: 1px solid rgb(255 255 255 / 0.56);
    border-radius: 24px;
    box-shadow: 0 20px 60px rgb(22 21 17 / 0.16);
    padding: 10px;
    /* Layout styling */
    display: flex;
    align-items: center;
    gap: var(--gap-md);

    @starting-style {
      opacity: 0;
      transform: translateX(-50%) translateY(calc(100% + 40px));
    }

    &::before {
      --border: 2px;
      content: '';
      position: absolute;
      inset: calc(var(--border) * -1);
      background: linear-gradient(rgb(255 255 255 / 0.88) 0 100%), linear-gradient(hsl(0 0% 0% / 0.12) 0 100%);
      background-clip: content-box, border-box;
      border: var(--border) solid #0000;
      border-radius: inherit;
      z-index: -1;
      backdrop-filter: blur(22px) saturate(160%);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .sticky-add-to-cart__bar {
      transition-property: transform, opacity, display;
      transition-duration: 0.3s;
      transition-timing-function: var(--ease-out-quad);
      transition-behavior: allow-discrete;
    }
  }

  .sticky-add-to-cart__bar[data-stuck='true'] {
    transform: translateX(-50%) translateY(0%);
    opacity: 1;
  }

  sticky-add-to-cart:not([data-variant-available='true']) .sticky-add-to-cart__bar {
    opacity: 0;
    transform: translateX(-50%) translateY(calc(100% + 40px));
    display: none;
  }

  .sticky-add-to-cart__info[data-has-image='false'] {
    padding-left: var(--padding-lg);
  }

  .sticky-add-to-cart__image {
    flex-shrink: 0;
    aspect-ratio: 1;
    height: var(--height-buy-buttons);
    overflow: hidden;
    border-radius: 16px;
    background: #fff;
  }

  .sticky-add-to-cart__image-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sticky-add-to-cart__info {
    flex: 1;
    min-width: 0; /* Allow text truncation */
  }

  .sticky-add-to-cart__title {
    font-size: var(--font-paragraph-medium--size);
    font-weight: 750;
    line-height: var(--font-paragraph--line-height);
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .sticky-add-to-cart__variant {
    color: rgb(22 21 17 / 0.58);
    font-size: var(--font-paragraph-small--size);
    margin-top: var(--margin-3xs);
  }

  .sticky-add-to-cart__price {
    color: #b88935;
    font-weight: 750;
  }

  .sticky-add-to-cart__button {
    height: var(--height-buy-buttons);
    position: relative;
    border: 0;
    border-radius: 18px;
    background: #b88935;
    color: #161511;
    font-weight: 800;
    transition: transform 220ms var(--ease-out-quad, ease), background 220ms ease;
  }

  .sticky-add-to-cart__button:hover {
    transform: translateY(-2px);
    background: #c99945;
  }

  /* Mobile adjustments */
  @media screen and (max-width: 749px) {
    .sticky-add-to-cart__bar {
      bottom: 0;
      width: 100%;
      max-width: none;
      border-radius: 0;

      &::before {
        --border: 1px;
      }
    }

    .sticky-add-to-cart__bar .add-to-cart-text__content {
      display: none;
    }

    .sticky-add-to-cart__info[data-has-image='false'] {
      padding-left: 0;
    }

    .sticky-add-to-cart__title {
      font-size: var(--font-paragraph--size);
    }

    .sticky-add-to-cart__button {
      padding: var(--padding-lg);
    }

    .sticky-add-to-cart__price {
      font-size: var(--font-paragraph-small--size);
    }

    .sticky-add-to-cart__button {
      width: var(--height-buy-buttons);
    }

    sticky-add-to-cart:not([data-variant-available='true']) .add-to-cart-text__content {
      display: initial;
    }

    sticky-add-to-cart:not([data-variant-available='true']) .sticky-add-to-cart__button {
      width: auto;
    }
  }

  /* Small mobile - hide text content and compare price */
  @media screen and (max-width: 389px) {
    .sticky-add-to-cart__bar {
      .compare-at-price {
        display: none;
      }
    }

    .sticky-add-to-cart__title {
      display: none;
    }

    /* For product with only default variant show title */
    .sticky-add-to-cart__info[data-singleton='true'] .sticky-add-to-cart__title {
      display: block;
    }

    /* For single variant show title and variant, truncate both. variant should be identifiable with truncation */
    .sticky-add-to-cart__info[data-single-option='true'] .sticky-add-to-cart__title {
      display: block;
    }

    .sticky-add-to-cart__info[data-single-option='true'] .sticky-add-to-cart__variant {
      display: block;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
  }
{% endstylesheet %}

{% schema %}
{

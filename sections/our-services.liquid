{% schema %}
{
  "name": "Premium Our Services",
  "settings": [
    {
      "type": "header",
      "content": "Layout & Spacing"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 1200,
      "max": 1800,
      "step": 50,
      "unit": "px",
      "label": "Container Maximum Width",
      "default": 1600
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 60,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Padding Top",
      "default": 140
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 60,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 140
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Section Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "color_heading",
      "label": "Heading Color",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Body Text Color",
      "default": "#4B5563"
    },
    {
      "type": "color",
      "id": "color_gold",
      "label": "Premium Gold",
      "default": "#D4AF37"
    },
    {
      "type": "color",
      "id": "color_green",
      "label": "Dark Green",
      "default": "#143122"
    },
    {
      "type": "header",
      "content": "Header Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Premium Marketplace Services"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Main Heading",
      "default": "Everything You Need To Trade Livestock With Confidence"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Stock Shop provides powerful marketplace tools and professional services designed to make buying and selling livestock easier, safer and faster."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Header Button Label",
      "default": "Explore All Services"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Header Button Link"
    },
    {
      "type": "header",
      "content": "CTA Banner"
    },
    {
      "type": "image_picker",
      "id": "cta_bg_image",
      "label": "Banner Background Image"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "Banner Heading",
      "default": "Ready To Start Buying Or Selling Livestock?"
    },
    {
      "type": "textarea",
      "id": "cta_desc",
      "label": "Banner Description",
      "default": "Join thousands of farmers and buyers using Stock Shop every day."
    },
    {
      "type": "text",
      "id": "cta_btn_1_text",
      "label": "Primary Button Text",
      "default": "Browse Listings"
    },
    {
      "type": "url",
      "id": "cta_btn_1_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "cta_btn_2_text",
      "label": "Secondary Button Text",
      "default": "Become A Seller"
    },
    {
      "type": "url",
      "id": "cta_btn_2_link",
      "label": "Secondary Button Link"
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service Card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon / Illustration",
          "options": [
            { "value": "shield", "label": "Shield Check" },
            { "value": "truck", "label": "Truck" },
            { "value": "stethoscope", "label": "Stethoscope" },
            { "value": "wallet", "label": "Wallet" },
            { "value": "award", "label": "Award" },
            { "value": "headset", "label": "Headset" }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Service Title",
          "default": "Service Name"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Brief description of the premium service offered."
        },
        {
          "type": "textarea",
          "id": "features",
          "label": "Feature List (One per line)",
          "default": "Identity Verification\nTrusted Profiles\nFraud Protection"
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button Text",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Button Link"
        }
      ]
    },
    {
      "type": "counter",
      "name": "Counter Statistic",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "15"
        },
        {
          "type": "text",
          "id": "suffix",
          "label": "Suffix (K+, %, etc.)",
          "default": "K+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Marketplace Listings"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Our Services",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "icon": "shield",
            "title": "Verified Seller Program",
            "description": "Every livestock seller is verified to ensure a trustworthy marketplace.",
            "features": "Identity Verification\nTrusted Profiles\nFraud Protection",
            "btn_text": "Learn More"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "truck",
            "title": "Livestock Transportation",
            "description": "Connect with reliable livestock transportation partners across the country.",
            "features": "Safe Delivery\nGPS Tracking\nNationwide Coverage",
            "btn_text": "Learn More"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "stethoscope",
            "title": "Veterinary Support",
            "description": "Access professional veterinary guidance before and after your purchase.",
            "features": "Health Consultation\nCertificates\nExpert Advice",
            "btn_text": "Learn More"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "wallet",
            "title": "Secure Marketplace Payments",
            "description": "Protected transactions designed for both buyers and sellers.",
            "features": "Safe Checkout\nPayment Protection\nTransaction History",
            "btn_text": "Learn More"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "award",
            "title": "Premium Seller Membership",
            "description": "Unlock premium listing tools and increase visibility across the marketplace.",
            "features": "Featured Listings\nBetter Exposure\nSeller Analytics",
            "btn_text": "Learn More"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "headset",
            "title": "Customer Support",
            "description": "Dedicated support team available whenever you need assistance.",
            "features": "Live Chat\nEmail Support\nPriority Assistance",
            "btn_text": "Learn More"
          }
        },
        { "type": "counter", "settings": { "number": "15", "suffix": "K+", "label": "Marketplace Listings" } },
        { "type": "counter", "settings": { "number": "6", "suffix": "K+", "label": "Verified Sellers" } },
        { "type": "counter", "settings": { "number": "24", "suffix": "/7", "label": "Support" } },
        { "type": "counter", "settings": { "number": "98", "suffix": "%", "label": "Successful Transactions" } }
      ]
    }
  ]
}
{% endschema %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600&display=swap');

  #shopify-section-{{ section.id }} {
    --srv-bg: {{ section.settings.color_bg }};
    --srv-heading: {{ section.settings.color_heading }};
    --srv-text: {{ section.settings.color_text }};
    --srv-gold: {{ section.settings.color_gold }};
    --srv-green: {{ section.settings.color_green }};
    --srv-gold-rgb: 212, 175, 55;
    --srv-green-rgb: 20, 49, 34;
    --srv-container-width: {{ section.settings.container_width }}px;
    --srv-padding-top: {{ section.settings.padding_top }}px;
    --srv-padding-bottom: {{ section.settings.padding_bottom }}px;
    
    background-color: var(--srv-bg);
    position: relative;
    overflow: hidden;
    font-family: 'Inter', sans-serif;
    color: var(--srv-text);
  }

  /* Typography */
  .srv-font-heading { font-family: 'Playfair Display', serif; }
  
  /* Decorative Backgrounds */
  .srv-bg-decor {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  .srv-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(140px);
    opacity: 0.15;
    z-index: 0;
    animation: srv-float-bg 20s ease-in-out infinite alternate;
  }
  .srv-blob-1 {
    top: -10%; left: -5%;
    width: 600px; height: 600px;
    background: var(--srv-gold);
  }
  .srv-blob-2 {
    bottom: 20%; right: -10%;
    width: 700px; height: 700px;
    background: var(--srv-green);
    animation-delay: -5s;
    opacity: 0.08;
  }
  .srv-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(var(--srv-gold-rgb), 0.15) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(circle at center, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(circle at center, black 20%, transparent 70%);
  }

  /* Container */
  .srv-container {
    max-width: var(--srv-container-width);
    margin: 0 auto;
    padding: var(--srv-padding-top) 40px var(--srv-padding-bottom);
    position: relative;
    z-index: 1;
  }

  /* Header Section */
  .srv-header-wrap {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 40px;
    margin-bottom: 80px;
  }
  .srv-header-content {
    max-width: 700px;
  }
  .srv-badge {
    display: inline-flex;
    align-items: center;
    background: rgba(var(--srv-gold-rgb), 0.1);
    color: #9A7B20; /* Darkened gold for contrast */
    font-weight: 600;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    padding: 8px 20px;
    border-radius: 50px;
    border: 1px solid rgba(var(--srv-gold-rgb), 0.3);
    margin-bottom: 24px;
  }
  .srv-h2 {
    font-size: clamp(36px, 4vw, 58px);
    font-weight: 700;
    color: var(--srv-heading);
    line-height: 1.15;
    margin: 0 0 24px 0;
    letter-spacing: -1px;
  }
  .srv-desc {
    font-size: 18px;
    line-height: 1.6;
    color: var(--srv-text);
    margin: 0;
  }
  
  .srv-btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 36px;
    border-radius: 50px;
    border: 2px solid #E5E7EB;
    background: transparent;
    color: var(--srv-heading);
    font-weight: 600;
    font-size: 16px;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    white-space: nowrap;
  }
  .srv-btn-outline svg {
    transition: transform 0.4s ease;
  }
  .srv-btn-outline:hover {
    border-color: var(--srv-gold);
    background: var(--srv-gold);
    color: var(--srv-green);
    box-shadow: 0 10px 25px rgba(var(--srv-gold-rgb), 0.25);
  }
  .srv-btn-outline:hover svg {
    transform: translateX(5px);
  }

  /* Grid Layout */
  .srv-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-bottom: 80px;
  }

  /* Cards */
  .srv-card {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid #ECECEC;
    border-radius: 28px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    display: flex;
    flex-direction: column;
  }
  .srv-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 28px;
    padding: 2px;
    background: linear-gradient(135deg, var(--srv-gold), transparent 60%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  .srv-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.06);
    background: #ffffff;
  }
  .srv-card:hover::after {
    opacity: 1;
  }

  /* Card Illustration Area */
  .srv-card-illu {
    height: 180px;
    position: relative;
    background: linear-gradient(135deg, rgba(var(--srv-gold-rgb), 0.08), rgba(var(--srv-green-rgb), 0.02));
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-bottom: 1px solid #F3F4F6;
  }
  .srv-illu-shape {
    position: absolute;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(255,255,255,0.8), rgba(255,255,255,0.2));
    backdrop-filter: blur(5px);
  }
  .srv-illu-shape-1 { width: 100px; height: 100px; top: -20px; right: -20px; }
  .srv-illu-shape-2 { width: 60px; height: 60px; bottom: 20px; left: 20px; }
  
  .srv-card-icon-3d {
    width: 80px;
    height: 80px;
    color: var(--srv-gold);
    filter: drop-shadow(0 10px 15px rgba(var(--srv-gold-rgb), 0.3));
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
    position: relative;
    z-index: 2;
  }
  .srv-card:hover .srv-card-icon-3d {
    transform: scale(1.1) translateY(-5px);
  }

  /* Card Body */
  .srv-card-body {
    padding: 32px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }
  .srv-card-title {
    font-size: 22px;
    font-weight: 600;
    color: var(--srv-heading);
    margin: 0 0 12px 0;
  }
  .srv-card-desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--srv-text);
    margin: 0 0 24px 0;
  }

  /* Features List */
  .srv-features {
    list-style: none;
    padding: 0;
    margin: 0 0 32px 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-grow: 1;
  }
  .srv-feature-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    font-weight: 500;
    color: var(--srv-heading);
    transition: transform 0.3s ease;
  }
  .srv-card:hover .srv-feature-item {
    transform: translateX(4px);
  }
  .srv-feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    background: rgba(var(--srv-green-rgb), 0.1);
    color: var(--srv-green);
    border-radius: 50%;
  }
  .srv-feature-icon svg {
    width: 12px;
    height: 12px;
  }

  /* Card Footer */
  .srv-card-footer {
    border-top: 1px solid #F3F4F6;
    padding-top: 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .srv-card-link {
    font-size: 15px;
    font-weight: 600;
    color: var(--srv-heading);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: color 0.3s ease;
  }
  .srv-card:hover .srv-card-link {
    color: var(--srv-gold);
  }
  .srv-card-arrow {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #F9FAFB;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--srv-heading);
    transition: all 0.4s ease;
  }
  .srv-card:hover .srv-card-arrow {
    background: var(--srv-gold);
    color: #fff;
    transform: translateX(4px);
    box-shadow: 0 4px 12px rgba(var(--srv-gold-rgb), 0.4);
  }

  /* Counter Strip */
  .srv-counters {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-bottom: 80px;
  }
  .srv-counter-card {
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid #ECECEC;
    border-radius: 20px;
    padding: 32px 24px;
    text-align: center;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }
  .srv-counter-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.04);
  }
  .srv-counter-val {
    font-size: 46px;
    font-weight: 700;
    color: var(--srv-green);
    line-height: 1;
    margin-bottom: 8px;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .srv-counter-label {
    font-size: 14px;
    font-weight: 500;
    color: var(--srv-text);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* CTA Banner */
  .srv-cta-banner {
    position: relative;
    border-radius: 40px;
    overflow: hidden;
    min-height: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 60px 40px;
    background-color: var(--srv-green);
    {% if section.settings.cta_bg_image != blank %}
      background-image: url('{{ section.settings.cta_bg_image | image_url: width: 1600 }}');
      background-size: cover;
      background-position: center;
    {% endif %}
  }
  .srv-cta-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(var(--srv-green-rgb), 0.9) 0%, rgba(var(--srv-green-rgb), 0.7) 100%);
    z-index: 1;
  }
  .srv-cta-overlay::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top right, rgba(var(--srv-gold-rgb), 0.4), transparent 60%);
  }
  .srv-cta-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 60px;
    border-radius: 30px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 25px 50px rgba(0,0,0,0.1);
  }
  .srv-cta-h3 {
    font-size: clamp(32px, 3.5vw, 48px);
    font-weight: 700;
    color: #fff;
    margin: 0 0 16px 0;
    line-height: 1.2;
  }
  .srv-cta-desc {
    font-size: 18px;
    color: rgba(255,255,255,0.85);
    margin: 0 0 40px 0;
  }
  .srv-cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .srv-btn-primary {
    background: var(--srv-gold);
    color: var(--srv-green);
    padding: 16px 36px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 16px;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 10px 20px rgba(var(--srv-gold-rgb), 0.3);
  }
  .srv-btn-primary:hover {
    background: #fff;
    transform: translateY(-3px);
  }
  .srv-btn-secondary {
    background: rgba(255,255,255,0.1);
    color: #fff;
    padding: 16px 36px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 16px;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.2);
    transition: all 0.3s ease;
  }
  .srv-btn-secondary:hover {
    background: rgba(255,255,255,0.2);
    border-color: #fff;
    transform: translateY(-3px);
  }

  /* Animations */
  @keyframes srv-float-bg {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(30px, -50px) scale(1.1); }
  }
  .srv-reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .srv-reveal.srv-active {
    opacity: 1;
    transform: translateY(0);
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .srv-grid { grid-template-columns: repeat(2, 1fr); }
    .srv-counters { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} {
      --srv-padding-top: {{ section.settings.padding_top | divided_by: 1.5 }}px;
      --srv-padding-bottom: {{ section.settings.padding_bottom | divided_by: 1.5 }}px;
    }
    .srv-container { padding-left: 20px; padding-right: 20px; }
    
    .srv-header-wrap {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
      margin-bottom: 40px;
    }
    .srv-grid {
      grid-template-columns: 1fr;
      gap: 24px;
      margin-bottom: 40px;
    }
    .srv-counters {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 16px;
      padding-bottom: 20px;
      margin-bottom: 40px;
      -webkit-overflow-scrolling: touch;
    }
    .srv-counters::-webkit-scrollbar { display: none; }
    .srv-counter-card {
      flex: 0 0 80%;
      scroll-snap-align: center;
    }
    .srv-cta-banner {
      padding: 40px 20px;
      border-radius: 28px;
    }
    .srv-cta-content {
      padding: 40px 24px;
    }
    .srv-cta-buttons {
      flex-direction: column;
      width: 100%;
    }
    .srv-btn-primary, .srv-btn-secondary {
      width: 100%;
    }
  }
</style>

<div class="srv-bg-decor">
  <div class="srv-blob srv-blob-1"></div>
  <div class="srv-blob srv-blob-2"></div>
  <div class="srv-dots"></div>
</div>

<div class="srv-container">
  
  <div class="srv-header-wrap srv-reveal">
    <div class="srv-header-content">
      {% if section.settings.badge_text != blank %}
        <div class="srv-badge">{{ section.settings.badge_text }}</div>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="srv-h2 srv-font-heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <p class="srv-desc">{{ section.settings.description }}</p>
      {% endif %}
    </div>
    {% if section.settings.btn_label != blank %}
      <a href="{{ section.settings.btn_link | default: '#' }}" class="srv-btn-outline">
        {{ section.settings.btn_label }}
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    {% endif %}
  </div>

  <div class="srv-grid">
    {% for block in section.blocks %}
      {% if block.type == 'service' %}
        <div class="srv-card srv-reveal" style="transition-delay: {{ forloop.index | times: 100 }}ms;" {{ block.shopify_attributes }}>
          
          <div class="srv-card-illu">
            <div class="srv-illu-shape srv-illu-shape-1"></div>
            <div class="srv-illu-shape srv-illu-shape-2"></div>
            
            {% case block.settings.icon %}
              {% when 'shield' %}
                <svg class="srv-card-icon-3d" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg>
              {% when 'truck' %}
                <svg class="srv-card-icon-3d" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
              {% when 'stethoscope' %}
                <svg class="srv-card-icon-3d" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"></path><path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6v-4"></path><circle cx="20" cy="10" r="2"></circle></svg>
              {% when 'wallet' %}
                <svg class="srv-card-icon-3d" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"></path><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"></path><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"></path></svg>
              {% when 'award' %}
                <svg class="srv-card-icon-3d" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>
              {% when 'headset' %}
                <svg class="srv-card-icon-3d" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"></path><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"></path></svg>
            {% endcase %}
          </div>

          <div class="srv-card-body">
            <h3 class="srv-card-title">{{ block.settings.title }}</h3>
            <p class="srv-card-desc">{{ block.settings.description }}</p>
            
            <ul class="srv-features">
              {% assign features = block.settings.features | split: '
' %}
              {% for feature in features %}
                {% if feature != blank %}
                  <li class="srv-feature-item">
                    <span class="srv-feature-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    </span>
                    {{ feature | strip }}
                  </li>
                {% endif %}
              {% endfor %}
            </ul>

            <div class="srv-card-footer">
              <a href="{{ block.settings.btn_link | default: '#' }}" class="srv-card-link">
                {{ block.settings.btn_text }}
              </a>
              <div class="srv-card-arrow">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </div>
            </div>
          </div>
          
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% assign has_counters = false %}
  {% for block in section.blocks %}
    {% if block.type == 'counter' %}{% assign has_counters = true %}{% break %}{% endif %}
  {% endfor %}

  {% if has_counters %}
    <div class="srv-counters srv-reveal">
      {% for block in section.blocks %}
        {% if block.type == 'counter' %}
          <div class="srv-counter-card" {{ block.shopify_attributes }}>
            <div class="srv-counter-val srv-font-heading">
              {% assign is_dec = false %}
              {% if block.settings.number contains '.' %}{% assign is_dec = true %}{% endif %}
              <span class="srv-count-up" data-target="{{ block.settings.number }}" data-dec="{% if is_dec %}1{% else %}0{% endif %}">0</span>{{ block.settings.suffix }}
            </div>
            <div class="srv-counter-label">{{ block.settings.label }}</div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}

  <div class="srv-cta-banner srv-reveal">
    <div class="srv-cta-overlay"></div>
    <div class="srv-cta-content">
      {% if section.settings.cta_heading != blank %}
        <h3 class="srv-cta-h3 srv-font-heading">{{ section.settings.cta_heading }}</h3>
      {% endif %}
      {% if section.settings.cta_desc != blank %}
        <p class="srv-cta-desc">{{ section.settings.cta_desc }}</p>
      {% endif %}
      
      <div class="srv-cta-buttons">
        {% if section.settings.cta_btn_1_text != blank %}
          <a href="{{ section.settings.cta_btn_1_link | default: '#' }}" class="srv-btn-primary">{{ section.settings.cta_btn_1_text }}</a>
        {% endif %}
        {% if section.settings.cta_btn_2_text != blank %}
          <a href="{{ section.settings.cta_btn_2_link | default: '#' }}" class="srv-btn-secondary">{{ section.settings.cta_btn_2_text }}</a>
        {% endif %}
      </div>
    </div>
  </div>

</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    function initServicesSection() {
      // Reveal on Scroll
      const revealElements = document.querySelectorAll('#shopify-section-{{ section.id }} .srv-reveal');
      const revealObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('srv-active');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

      revealElements.forEach(el => revealObserver.observe(el));

      // Count Up Animation
      const countElements = document.querySelectorAll('#shopify-section-{{ section.id }} .srv-count-up');
      const countObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && !entry.target.classList.contains('counted')) {
            runCountUp(entry.target);
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.5 });

      countElements.forEach(el => countObserver.observe(el));

      function runCountUp(el) {
        const target = parseFloat(el.getAttribute('data-target'));
        const decimals = el.getAttribute('data-dec') === '1';
        const duration = 2000;
        let startTime = null;

        function animationStep(timestamp) {
          if (!startTime) startTime = timestamp;
          const progress = Math.min((timestamp - startTime) / duration, 1);
          const easeOut = 1 - Math.pow(1 - progress, 4); // easeOutQuart
          const current = easeOut * target;
          
          if (decimals) {
            el.innerText = current.toFixed(1);
          } else {
            el.innerText = Math.floor(current);
          }

          if (progress < 1) {
            requestAnimationFrame(animationStep);
          } else {
            el.innerText = decimals ? target.toFixed(1) : parseInt(target, 10);
            el.classList.add('counted');
          }
        }
        requestAnimationFrame(animationStep);
      }
    }

    initServicesSection();

    // Theme Editor Support
    if (window.Shopify && Shopify.DesignMode) {
      document.addEventListener('shopify:section:load', function(event) {
        if (event.detail.sectionId === '{{ section.id }}') {
          initServicesSection();
        }
      });
    }
  });
</script>
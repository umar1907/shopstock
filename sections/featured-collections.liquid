{%- comment -%}
  Stock Shop — Premium Featured Collections Section
  Custom built. Not based on Dawn/Prestige/Impulse.
{%- endcomment -%}

{%- liquid
  assign sc_heading = section.settings.heading
  assign sc_subheading = section.settings.subheading
  assign sc_badge = section.settings.badge_text
  assign sc_btn_label = section.settings.button_label
  assign sc_btn_url = section.settings.button_url
  assign sc_primary = section.settings.primary_color
  assign sc_secondary = section.settings.secondary_color
  assign sc_bg = section.settings.background_color
  assign sc_text = section.settings.text_color
  assign sc_radius = section.settings.card_radius
  assign sc_cols_desktop = section.settings.columns_desktop
  assign sc_cols_tablet = section.settings.columns_tablet
  assign sc_cols_mobile = section.settings.columns_mobile
  assign sc_container_width = section.settings.container_width
  assign sc_padding_top = section.settings.padding_top
  assign sc_padding_bottom = section.settings.padding_bottom
  assign sc_enable_stats = section.settings.enable_stats
  assign sc_enable_animation = section.settings.enable_animation
-%}

<section
  id="StockShop-FeaturedCollections-{{ section.id }}"
  class="ss-featured-collections{% unless sc_enable_animation %} ss-no-animate{% endunless %}"
  style="
    --ss-primary: {{ sc_primary }};
    --ss-secondary: {{ sc_secondary }};
    --ss-bg: {{ sc_bg }};
    --ss-text: {{ sc_text }};
    --ss-radius: {{ sc_radius }}px;
    --ss-container-width: {{ sc_container_width }}px;
    --ss-pad-top: {{ sc_padding_top }}px;
    --ss-pad-bottom: {{ sc_padding_bottom }}px;
    --ss-cols-desktop: {{ sc_cols_desktop }};
    --ss-cols-tablet: {{ sc_cols_tablet }};
    --ss-cols-mobile: {{ sc_cols_mobile }};
  "
  aria-label="{{ sc_heading | strip_html | escape }}"
>

  <div class="ss-fc__decor" aria-hidden="true">
    <span class="ss-fc__blob ss-fc__blob--1"></span>
    <span class="ss-fc__blob ss-fc__blob--2"></span>
    <span class="ss-fc__line ss-fc__line--1"></span>
    <span class="ss-fc__line ss-fc__line--2"></span>
    <span class="ss-fc__particle ss-fc__particle--1"></span>
    <span class="ss-fc__particle ss-fc__particle--2"></span>
    <span class="ss-fc__particle ss-fc__particle--3"></span>
  </div>

  <div class="ss-fc__container">

    <header class="ss-fc__header ss-reveal">
      <div class="ss-fc__header-text">
        {%- if sc_badge != blank -%}
          <span class="ss-fc__badge">{{ sc_badge }}</span>
        {%- endif -%}
        {%- if sc_heading != blank -%}
          <h2 class="ss-fc__heading">{{ sc_heading }}</h2>
        {%- endif -%}
        {%- if sc_subheading != blank -%}
          <p class="ss-fc__subheading">{{ sc_subheading }}</p>
        {%- endif -%}
      </div>

      {%- if sc_btn_label != blank -%}
        <a
          href="{{ sc_btn_url | default: '#' }}"
          class="ss-fc__cta"
        >
          <span>{{ sc_btn_label }}</span>
          <svg class="ss-fc__cta-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {%- endif -%}
    </header>

    {%- if sc_enable_stats -%}
      <div class="ss-fc__stats ss-reveal">
        {%- for i in (1..4) -%}
          {%- assign stat_value_key = 'stat_' | append: i | append: '_value' -%}
          {%- assign stat_label_key = 'stat_' | append: i | append: '_label' -%}
          {%- assign stat_value = section.settings[stat_value_key] -%}
          {%- assign stat_label = section.settings[stat_label_key] -%}
          {%- if stat_value != blank -%}
            <div class="ss-fc__stat-card">
              <span class="ss-fc__stat-value" data-count-up data-target="{{ stat_value }}">{{ stat_value }}</span>
              <span class="ss-fc__stat-label">{{ stat_label }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="ss-fc__grid" role="list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign collection = block.settings.collection
            assign custom_image = block.settings.custom_image
            assign badge_text = block.settings.badge_text
            assign enable_badge = block.settings.enable_badge
            assign enable_overlay = block.settings.enable_overlay
            assign enable_hover = block.settings.enable_hover
            assign listing_count = block.settings.listing_count
            assign description = block.settings.description
            assign card_title = block.settings.title
            assign card_url = block.settings.button_url

            if collection != blank
              assign final_title = card_title | default: collection.title
              assign final_url = card_url | default: collection.url
              assign final_count = listing_count | default: collection.products_count
              assign final_image = custom_image | default: collection.featured_image
            else
              assign final_title = card_title
              assign final_url = card_url | default: '#'
              assign final_count = listing_count
              assign final_image = custom_image
            endif
          -%}

          <a
            href="{{ final_url }}"
            class="ss-fc__card ss-reveal{% unless enable_hover %} ss-fc__card--no-hover{% endunless %}"
            role="listitem"
            style="--delay: {{ forloop.index0 | times: 80 }}ms;"
            aria-label="{{ final_title | strip_html | escape }}, {{ final_count }} listings"
          >
            <div class="ss-fc__card-media">
              {%- if final_image != blank -%}
                <img
                  src="{{ final_image | image_url: width: 900 }}"
                  srcset="{{ final_image | image_url: width: 450 }} 450w, {{ final_image | image_url: width: 900 }} 900w, {{ final_image | image_url: width: 1200 }} 1200w"
                  sizes="(max-width: 749px) 80vw, (max-width: 1099px) 33vw, 16vw"
                  alt="{{ final_image.alt | default: final_title | escape }}"
                  loading="lazy"
                  width="{{ final_image.width }}"
                  height="{{ final_image.height }}"
                  class="ss-fc__card-img"
                />
              {%- else -%}
                <div class="ss-fc__card-img ss-fc__card-img--placeholder">
                  {{ 'collection-1' | placeholder_svg_tag: 'ss-fc__placeholder-svg' }}
                </div>
              {%- endif -%}

              {%- if enable_overlay -%}
                <span class="ss-fc__card-overlay" aria-hidden="true"></span>
              {%- endif -%}

              {%- if enable_badge and badge_text != blank -%}
                <span class="ss-fc__card-badge">{{ badge_text }}</span>
              {%- endif -%}

              <span class="ss-fc__card-arrow" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>

            <div class="ss-fc__card-content">
              <h3 class="ss-fc__card-title">{{ final_title }}</h3>
              <div class="ss-fc__card-meta">
                {%- if final_count != blank -%}
                  <span class="ss-fc__card-count">{{ final_count }} Listings</span>
                {%- endif -%}
              </div>
              {%- if description != blank -%}
                <p class="ss-fc__card-desc">{{ description }}</p>
              {%- endif -%}
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="ss-fc__empty-state">
        <p>Add collection blocks in the section editor to display categories here.</p>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  #StockShop-FeaturedCollections-{{ section.id }} {
    --ss-shadow-soft: 0 10px 30px rgba(20, 20, 20, 0.06);
    --ss-shadow-lift: 0 30px 60px -15px rgba(20, 20, 20, 0.18);
    --ss-ease: cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
    background: var(--ss-bg);
    color: var(--ss-text);
    padding-top: var(--ss-pad-top);
    padding-bottom: var(--ss-pad-bottom);
    font-family: inherit;
  }

  #StockShop-FeaturedCollections-{{ section.id }} * {
    box-sizing: border-box;
  }

  /* ---------- Container ---------- */
  .ss-fc__container {
    max-width: var(--ss-container-width);
    margin: 0 auto;
    padding: 0 40px;
    position: relative;
    z-index: 2;
  }

  @media (max-width: 749px) {
    .ss-fc__container { padding: 0 20px; }
  }

  /* ---------- Decorative Elements ---------- */
  .ss-fc__decor {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }

  .ss-fc__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    opacity: 0.12;
  }

  .ss-fc__blob--1 {
    width: 420px;
    height: 420px;
    top: -120px;
    right: -100px;
    background: radial-gradient(circle, var(--ss-primary), transparent 70%);
  }

  .ss-fc__blob--2 {
    width: 360px;
    height: 360px;
    bottom: -140px;
    left: -120px;
    background: radial-gradient(circle, var(--ss-secondary), transparent 70%);
  }

  .ss-fc__line {
    position: absolute;
    background: linear-gradient(90deg, transparent, var(--ss-primary), transparent);
    opacity: 0.25;
  }

  .ss-fc__line--1 {
    width: 1px;
    height: 220px;
    top: 40px;
    left: 8%;
    background: linear-gradient(180deg, transparent, var(--ss-primary), transparent);
  }

  .ss-fc__line--2 {
    width: 1px;
    height: 160px;
    bottom: 40px;
    right: 12%;
    background: linear-gradient(180deg, transparent, var(--ss-primary), transparent);
  }

  .ss-fc__particle {
    position: absolute;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--ss-primary);
    opacity: 0.35;
    animation: ss-fc-float 7s ease-in-out infinite;
  }

  .ss-fc__particle--1 { top: 20%; left: 18%; animation-delay: 0s; }
  .ss-fc__particle--2 { top: 65%; left: 85%; animation-delay: 2s; }
  .ss-fc__particle--3 { top: 40%; left: 50%; animation-delay: 4s; }

  @keyframes ss-fc-float {
    0%, 100% { transform: translateY(0); opacity: 0.2; }
    50% { transform: translateY(-18px); opacity: 0.45; }
  }

  /* ---------- Header ---------- */
  .ss-fc__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 40px;
    margin-bottom: 64px;
    flex-wrap: wrap;
  }

  .ss-fc__header-text {
    max-width: 700px;
  }

  .ss-fc__badge {
    display: inline-flex;
    align-items: center;
    padding: 7px 18px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--ss-primary), color-mix(in srgb, var(--ss-primary) 70%, white));
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 22px;
  }

  .ss-fc__heading {
    font-size: 56px;
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 0 0 18px;
    max-width: 700px;
  }

  .ss-fc__subheading {
    font-size: 18px;
    line-height: 1.6;
    color: color-mix(in srgb, var(--ss-text) 65%, transparent);
    max-width: 650px;
    margin: 0;
  }

  .ss-fc__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 28px;
    border-radius: 999px;
    border: 1.5px solid var(--ss-text);
    color: var(--ss-text);
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    white-space: nowrap;
    transition: background 350ms var(--ss-ease), color 350ms var(--ss-ease), border-color 350ms var(--ss-ease), transform 350ms var(--ss-ease);
    flex-shrink: 0;
  }

  .ss-fc__cta:hover {
    background: var(--ss-primary);
    border-color: var(--ss-primary);
    color: #fff;
    transform: translateY(-2px);
  }

  .ss-fc__cta-arrow {
    transition: transform 350ms var(--ss-ease);
  }

  .ss-fc__cta:hover .ss-fc__cta-arrow {
    transform: translateX(4px);
  }

  /* ---------- Stats ---------- */
  .ss-fc__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 72px;
  }

  .ss-fc__stat-card {
    text-align: center;
    padding: 30px 16px;
    border-radius: 20px;
    background: color-mix(in srgb, var(--ss-bg) 50%, white 50%);
    backdrop-filter: blur(10px);
    border: 1px solid color-mix(in srgb, var(--ss-text) 8%, transparent);
    box-shadow: var(--ss-shadow-soft);
    transition: transform 350ms var(--ss-ease), box-shadow 350ms var(--ss-ease);
  }

  .ss-fc__stat-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--ss-shadow-lift);
  }

  .ss-fc__stat-value {
    display: block;
    font-size: 34px;
    font-weight: 700;
    color: var(--ss-primary);
    letter-spacing: -0.01em;
    margin-bottom: 6px;
  }

  .ss-fc__stat-label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: color-mix(in srgb, var(--ss-text) 60%, transparent);
  }

  @media (max-width: 989px) {
    .ss-fc__stats { grid-template-columns: repeat(2, 1fr); }
  }

  /* ---------- Grid ---------- */
  .ss-fc__grid {
    display: grid;
    grid-template-columns: repeat(var(--ss-cols-desktop), 1fr);
    gap: 28px;
  }

  @media (max-width: 1099px) and (min-width: 750px) {
    .ss-fc__grid { grid-template-columns: repeat(var(--ss-cols-tablet), 1fr); }
  }

  @media (max-width: 749px) {
    .ss-fc__grid {
      grid-template-columns: none;
      grid-auto-flow: column;
      grid-auto-columns: 80%;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding-bottom: 12px;
      margin: 0 -20px;
      padding-left: 20px;
      padding-right: 20px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .ss-fc__grid::-webkit-scrollbar { display: none; }
    .ss-fc__card { scroll-snap-align: start; }
  }

  /* ---------- Card ---------- */
  .ss-fc__card {
    position: relative;
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: var(--ss-radius);
    overflow: hidden;
    background: color-mix(in srgb, var(--ss-bg) 60%, white 40%);
    box-shadow: var(--ss-shadow-soft);
    border: 1px solid transparent;
    transition: transform 350ms var(--ss-ease), box-shadow 350ms var(--ss-ease), border-color 350ms var(--ss-ease);
  }

  .ss-fc__card:not(.ss-fc__card--no-hover):hover {
    transform: translateY(-8px);
    box-shadow: var(--ss-shadow-lift);
    border-color: color-mix(in srgb, var(--ss-primary) 50%, transparent);
  }

  .ss-fc__card-media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--ss-radius) var(--ss-radius) 0 0;
    background: color-mix(in srgb, var(--ss-text) 6%, transparent);
  }

  .ss-fc__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 600ms var(--ss-ease);
  }

  .ss-fc__card-img--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
  }

  .ss-fc__placeholder-svg {
    width: 100%;
    height: 100%;
    opacity: 0.5;
  }

  .ss-fc__card:not(.ss-fc__card--no-hover):hover .ss-fc__card-img {
    transform: scale(1.08);
  }

  .ss-fc__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.05) 55%, transparent 100%);
    pointer-events: none;
  }

  .ss-fc__card-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    padding: 6px 14px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--ss-primary), color-mix(in srgb, var(--ss-primary) 70%, white));
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    z-index: 2;
  }

  .ss-fc__card-arrow {
    position: absolute;
    bottom: 16px;
    right: 16px;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: var(--ss-primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: transform 350ms var(--ss-ease), width 350ms var(--ss-ease);
    overflow: hidden;
  }

  .ss-fc__card:not(.ss-fc__card--no-hover):hover .ss-fc__card-arrow {
    transform: translateX(-2px) rotate(45deg);
    width: 48px;
  }

  .ss-fc__card-content {
    padding: 22px 22px 26px;
  }

  .ss-fc__card-title {
    font-size: 21px;
    font-weight: 700;
    margin: 0 0 6px;
    letter-spacing: -0.01em;
    transition: color 350ms var(--ss-ease);
  }

  .ss-fc__card:not(.ss-fc__card--no-hover):hover .ss-fc__card-title {
    color: var(--ss-primary);
  }

  .ss-fc__card-meta {
    margin-bottom: 8px;
  }

  .ss-fc__card-count {
    font-size: 13px;
    font-weight: 600;
    color: color-mix(in srgb, var(--ss-text) 55%, transparent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .ss-fc__card-desc {
    font-size: 14px;
    line-height: 1.5;
    color: color-mix(in srgb, var(--ss-text) 60%, transparent);
    margin: 0;
  }

  .ss-fc__empty-state {
    text-align: center;
    padding: 60px 20px;
    border: 1px dashed color-mix(in srgb, var(--ss-text) 25%, transparent);
    border-radius: var(--ss-radius);
    color: color-mix(in srgb, var(--ss-text) 55%, transparent);
  }

  /* ---------- Reveal Animation ---------- */
  .ss-reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 700ms var(--ss-ease), transform 700ms var(--ss-ease);
    transition-delay: var(--delay, 0ms);
  }

  .ss-reveal.ss-fc--visible {
    opacity: 1;
    transform: translateY(0);
  }

  .ss-no-animate .ss-reveal {
    opacity: 1;
    transform: none;
    transition: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .ss-reveal,
    .ss-fc__card-img,
    .ss-fc__card-arrow,
    .ss-fc__card-title,
    .ss-fc__cta,
    .ss-fc__cta-arrow,
    .ss-fc__stat-card {
      transition: none !important;
      animation: none !important;
    }
    .ss-reveal { opacity: 1; transform: none; }
  }

  @media (max-width: 749px) {
    .ss-fc__heading { font-size: 36px; }
    .ss-fc__header { margin-bottom: 40px; }
    .ss-fc__stats { margin-bottom: 48px; }
  }
</style>

<script>
  (function () {
    var root = document.getElementById('StockShop-FeaturedCollections-{{ section.id }}');
    if (!root) return;

    /* Scroll reveal */
    var revealEls = root.querySelectorAll('.ss-reveal');
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('ss-fc--visible');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
      revealEls.forEach(function (el) { io.observe(el); });
    } else {
      revealEls.forEach(function (el) { el.classList.add('ss-fc--visible'); });
    }

    /* Count-up stats */
    var statEls = root.querySelectorAll('[data-count-up]');
    function parseTarget(raw) {
      var match = String(raw).match(/[\d.]+/);
      return match ? parseFloat(match[0]) : null;
    }
    function animateCount(el) {
      var raw = el.getAttribute('data-target');
      var target = parseTarget(raw);
      if (target === null) return;
      var prefix = String(raw).split(target)[0] || '';
      var suffix = String(raw).split(target)[1] || '';
      var duration = 1400;
      var start = null;
      function step(ts) {
        if (!start) start = ts;
        var progress = Math.min((ts - start) / duration, 1);
        var eased = 1 - Math.pow(1 - progress, 3);
        var current = Math.floor(eased * target);
        el.textContent = prefix + current.toLocaleString() + suffix;
        if (progress < 1) {
          requestAnimationFrame(step);
        } else {
          el.textContent = raw;
        }
      }
      requestAnimationFrame(step);
    }

    if (statEls.length && 'IntersectionObserver' in window) {
      var statIo = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            animateCount(entry.target);
            statIo.unobserve(entry.target);
          }
        });
      }, { threshold: 0.4 });
      statEls.forEach(function (el) { statIo.observe(el); });
    }
  })();
</script>

{% schema %}
{
  "name": "Featured Collections",
  "tag": "section",
  "class": "ss-section-featured-collections",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Explore Categories"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Browse Livestock Categories"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Description",
      "default": "Find premium cattle, horses, sheep, goats, poultry and professional farm equipment from verified sellers across the country."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View All Categories"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Statistics"
    },
    {
      "type": "checkbox",
      "id": "enable_stats",
      "label": "Enable statistics row",
      "default": true
    },
    {
      "type": "text",
      "id": "stat_1_value",
      "label": "Stat 1 value",
      "default": "12,000+"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 label",
      "default": "Active Listings"
    },
    {
      "type": "text",
      "id": "stat_2_value",

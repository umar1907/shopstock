{% schema %}
{
  "name": "t:sections.header-banner.name",
  "tag": "section",
  "class": "header-banner-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "t:sections.header-banner.settings.banner_image.label",
      "info": "t:sections.header-banner.settings.banner_image.info"
    },
    {
      "type": "text",
      "id": "banner_title",
      "label": "t:sections.header-banner.settings.banner_title.label",
      "default": "Premium Stock Market Dashboard"
    },
    {
      "type": "textarea",
      "id": "banner_subtitle",
      "label": "t:sections.header-banner.settings.banner_subtitle.label",
